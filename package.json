{
    "name": "@biblebites/editorjs-renderer-react-native",
    "version": "0.0.0",
    "export-properties": {
        "main": "./dist/index.js",
        "module": "./dist/index.mjs",
        "types": "./dist/index.d.ts"
    },
    "scripts": {
        "prepare": "npm run build",
        "prepare-export-properties": "node prepare.js",
        "build": "tsup src/index.tsx --format esm,cjs --dts --minify --sourcemap --external react,react-native",
        "dev": "expo start --clear",
        "format": "biome check --write .",
        "lint": "biome lint . && tsc --noEmit",
        "test": "echo \"Error: no test specified\""
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/BibleBites/editorjs-renderer-react-native"
    },
    "author": "BibleBites",
    "license": "MIT",
    "description": "A React Native viewer for JSON created by EditorJs",
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-native": ">=0.72.0"
    },
    "dependencies": {
        "html-entities": "^2.5.2"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.10",
        "@types/react": "~19.2.10",
        "@types/react-native": "^0.72.8",
        "expo": "~55.0.12",
        "expo-router": "~55.0.11",
        "react": "19.2.0",
        "react-dom": "19.2.0",
        "react-native": "0.83.4",
        "react-native-safe-area-context": "~5.6.2",
        "react-native-web": "^0.21.0",
        "tsup": "^8.4.0",
        "typescript": "~6.0.2"
    },
    "files": [
        "dist/*"
    ]
}
